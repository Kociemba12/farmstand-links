# Backend API server port.
# IMPORTANT: Must NOT be 3000 — the Next.js link site (root project) runs on 3000.
# Use 3002. Update EXPO_PUBLIC_VIBECODE_BACKEND_URL in mobile/.env to match.
PORT=3002

RESEND_API_KEY=re_...

SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_JWT_SECRET=
